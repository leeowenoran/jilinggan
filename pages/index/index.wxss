/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 0 32rpx 200rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  padding: 48rpx 0 32rpx;
  display: flex;
  flex-direction: column;
}
.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.header-left {
  display: flex;
  flex-direction: column;
}
.header-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 4rpx;
}
.header-btn {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  transition: all 0.2s;
}
.header-btn:active {
  background: #F3F4F6;
  transform: scale(0.91);
  box-shadow: none;
}
.header-btn-icon {
  width: 46rpx;
  height: 46rpx;
  background-color: #374151;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  -webkit-mask-size: contain;
  mask-size: contain;
}
