<!--pages/detail/detail.wxml-->
<!-- 隐藏 Canvas，用于生成分享卡片（页面级，生命周期可靠） -->
<canvas
  type="2d"
  id="shareCanvas"
  class="share-canvas"
></canvas>

<view class="page">
  <!-- 顶部导航栏（标题 + 操作按钮） -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="onBack">
      <view class="nav-back-icon">
        <view class="chevron-icon"></view>
      </view>
    </view>
    <text class="nav-title">灵感详情</text>
    <view class="nav-actions">
      <!-- 吸收/取消 -->
      <view class="nav-btn {{item.absorbed ? 'absorbed' : ''}}" bindtap="onToggleAbsorb" wx:if="{{!isEditing}}">
        <text class="nav-btn-text">{{item.absorbed ? '已吸收' : '吸收'}}</text>
      </view>
      <!-- 更多操作 -->
      <view class="nav-btn" bindtap="onShowMore" wx:if="{{!isEditing}}">
        <text class="nav-btn-icon">…</text>
      </view>
    </view>
  </view>

  <view class="content-area" wx:if="{{item}}">
    <!-- 编辑模式 -->
    <block wx:if="{{isEditing}}">
      <view class="edit-section">
        <textarea
          class="edit-content"
          value="{{editContent}}"
          placeholder="灵感内容..."
          bindinput="onContentInput"
          auto-height
          maxlength="2000"
          focus="{{true}}"
        />
        <view class="edit-divider"></view>
        <textarea
          class="edit-supplement"
          value="{{editSupplement}}"
          placeholder="补充说明（可选）..."
          bindinput="onSupplementInput"
          auto-height
          maxlength="2000"
        />
      </view>
      <view class="edit-actions">
        <button class="btn-cancel" bindtap="onCancelEdit">取消</button>
        <button class="btn-save" bindtap="onSaveEdit">保存</button>
      </view>
    </block>

    <!-- 查看模式 -->
    <block wx:else>
      <view class="detail-content" bindlongpress="onStartEdit">
        <text class="content-text" wx:if="{{item.content}}">{{item.content}}</text>
        <text class="content-empty" wx:else>（无文字内容）</text>

        <!-- 图片区 -->
        <view wx:if="{{imageList.length > 0}}" class="image-grid">
          <view
            wx:for="{{imageList}}"
            wx:key="*this"
            wx:for-index="idx"
            class="image-wrap"
            bindtap="onPreviewImage"
            data-index="{{idx}}"
          >
            <image class="detail-image" src="{{item}}" mode="aspectFill" />
          </view>
        </view>

        <!-- 补充内容 -->
        <view class="supplement-section" wx:if="{{item.supplement}}">
          <text class="supplement-label">补充说明</text>
          <text class="supplement-text">{{item.supplement}}</text>
        </view>

        <!-- 标签区 -->
        <view class="tag-row" wx:if="{{projectName || item.tags.length > 0}}">
          <text class="tag tag-project" wx:if="{{projectName}}">{{projectName}}</text>
          <text class="tag tag-normal" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
        </view>

        <!-- 底部信息 -->
        <view class="meta-row">
          <text class="meta-text">{{displayDate}} {{displayTime}}</text>
          <text class="meta-text" wx:if="{{item.source === 'voice'}}">· 语音录入</text>
        </view>
      </view>

      <!-- 操作按钮栏 -->
      <view class="action-bar">
        <button class="action-btn" bindtap="onCopy">
          <text class="action-icon">📋</text>
          <text>复制</text>
        </button>
        <button class="action-btn" bindtap="onStartEdit">
          <text class="action-icon">✏️</text>
          <text>编辑</text>
        </button>
        <button class="action-btn" bindtap="onToggleAbsorb">
          <text class="action-icon">{{item.absorbed ? '🔓' : '✅'}}</text>
          <text>{{item.absorbed ? '取消吸收' : '标记吸收'}}</text>
        </button>
        <view class="action-btn" bindtap="onShare">
          <text class="action-icon">📤</text>
          <text>分享</text>
        </view>
        <button class="action-btn danger" bindtap="onDelete">
          <text class="action-icon">🗑️</text>
          <text>删除</text>
        </button>
      </view>
    </block>
  </view>

  <!-- 分享菜单（纯展示，不含 Canvas） -->
  <share-menu
    wx:if="{{showShareMenu}}"
    card-image-path="{{shareCardPath}}"
    is-generating="{{shareGenerating}}"
    generate-error="{{shareError}}"
    bind:close="onCloseShareMenu"
    bind:cardready="onShareCardReady"
    bind:retry="onRetryShareCard"
    bind:save="onSaveShareCard"
    bind:copytext="onCopyShareText"
  />
</view>
