/* components/share-menu/index.wxss */

/* 隐藏的 Canvas */
.share-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750rpx;
  height: 1000rpx;
}

/* 遮罩 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 底部弹出面板 */
.sheet {
  width: 100%;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
  overflow-y: auto;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 头部 */
.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx 24rpx;
}
.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}
.sheet-close {
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 8rpx 16rpx;
}

/* 卡片预览 */
.card-preview {
  margin: 0 40rpx 32rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #F9FAFB;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}
.card-image {
  width: 100%;
  display: block;
}
.card-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #E5E7EB;
  border-top-color: #10B981;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 操作按钮组 */
.sheet-actions {
  display: flex;
  gap: 20rpx;
  padding: 0 40rpx 32rpx;
}
.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 28rpx 0;
  background: #F9FAFB;
  border: none;
  border-radius: 20rpx;
  transition: all 0.15s;
  line-height: 1;
  margin: 0;
}
.action-btn::after {
  border: none;
}
.action-btn:active {
  background: #F3F4F6;
  transform: scale(0.97);
}
.action-btn[disabled] {
  opacity: 0.4;
}
.action-icon {
  width: 48rpx;
  height: 48rpx;
  background-color: #374151;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  -webkit-mask-size: contain;
  mask-size: contain;
}
.action-label {
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

