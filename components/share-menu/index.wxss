/* components/share-menu/index.wxss */

/* 隐藏的 Canvas */
.share-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750rpx;
  height: 1400rpx;
}

/* 遮罩 */
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 底部弹出面板 */
.sheet {
  width: 100%;
  max-height: 90vh;
  background: #FFFFFF;
  border-radius: 36rpx 36rpx 0 0;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  overflow-y: auto;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 头部 */
.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 40rpx 20rpx;
}
.sheet-title-area {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.2;
}
.sheet-subtitle {
  font-size: 22rpx;
  color: #9CA3AF;
}
.sheet-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F6;
  border-radius: 50%;
  font-size: 24rpx;
  color: #6B7280;
  text-align: center;
  line-height: 56rpx;
}

/* 卡片预览 */
.card-preview {
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #F9FAFB;
  box-shadow: 0 4rpx 32rpx rgba(0, 0, 0, 0.10);
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-image {
  width: 100%;
  display: block;
}

/* 加载状态 */
.card-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  gap: 24rpx;
}
.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 5rpx solid #E5E7EB;
  border-top-color: #10B981;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

/* 错误状态 */
.card-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}
.error-icon {
  font-size: 64rpx;
  color: #F59E0B;
}
.error-text {
  font-size: 28rpx;
  color: #6B7280;
}
.retry-link {
  font-size: 26rpx;
  color: #10B981;
  padding: 12rpx 32rpx;
  border: 2rpx solid #10B981;
  border-radius: 32rpx;
}

/* 操作按钮组 */
.sheet-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx 8rpx;
}
.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 28rpx 0;
  background: #F9FAFB;
  border: none;
  border-radius: 24rpx;
  transition: all 0.15s;
  line-height: 1;
  margin: 0;
}
.action-btn.primary {
  background: #E8F8EE;
}
.action-btn::after {
  border: none;
}
.action-btn:active {
  transform: scale(0.96);
  background: #F3F4F6;
}
.action-btn[disabled] {
  opacity: 0.35;
}
.action-icon {
  width: 52rpx;
  height: 52rpx;
  background-color: #374151;
  background-repeat: no-repeat;
  background-position: center;
  background-size: contain;
  -webkit-mask-size: contain;
  mask-size: contain;
}
.action-btn.primary .action-icon {
  background-color: #10B981;
}
.action-label {
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}
.action-btn.primary .action-label {
  color: #10B981;
}

/* 底部提示 */
.sheet-tip {
  padding: 0 32rpx 4rpx;
}
.tip-text {
  font-size: 22rpx;
  color: #B0B7C3;
  line-height: 1.6;
  display: block;
  text-align: center;
}

